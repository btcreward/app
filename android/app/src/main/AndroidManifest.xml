<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ✅ INTERNET: Required for API calls, AdMob ads, Firebase, and backend sync -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- ✅ POST_NOTIFICATIONS: Required to send mining status & reward alerts to user (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- ✅ VIBRATE: Used for notification vibration feedback when rewards are earned -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- ✅ WAKE_LOCK: Keeps CPU awake during active BTC reward computation simulation gameplay session -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- ✅ RECEIVE_BOOT_COMPLETED: Restarts scheduled reward & mining notifications after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- ✅ FOREGROUND_SERVICE: Required to run mining status notification as a foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- ✅ FOREGROUND_SERVICE_DATA_SYNC: Android 14+ requirement for dataSync foreground service type -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- ✅ ACCESS_NETWORK_STATE: Checks internet connectivity before API calls and ad loading -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- ✅ AD_ID: Required for AdMob Advertising ID on Android 13+ per Google policy -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" />

    <!-- ✅ Unity Ads Permissions -->
    <!-- ACCESS_WIFI_STATE: Needed for Unity Ads to check network/connection quality -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <!-- CHANGE_WIFI_STATE: Needed for Unity Ads SDK connectivity management -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />

    <application
        android:label="BTC Reward"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:usesCleartextTraffic="false"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- ✅ AdMob App ID -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-9510341737360907~6383161275" />

        <!-- ✅ Unity Ads Game ID for Android -->
        <meta-data
            android:name="unity.ads.game-id"
            android:value="800000486" />

        <!-- ✅ Unity Ads Test Mode: false for production release -->
        <meta-data
            android:name="unity.ads.test-mode"
            android:value="false" />

        <!-- ✅ Firebase Messaging Services -->
        <service
            android:name="io.flutter.plugins.firebase.messaging.FlutterFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- ✅ Mining Status Foreground Service (Android 14+ compliance) -->
        <!-- Purpose: Shows live BTC reward computation status notifications to user during gameplay -->
        <!-- Data Safety justification: dataSync type - syncs mining progress data to notification -->
        <service
            android:name=".MiningNotificationService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <receiver
            android:name="io.flutter.plugins.firebase.messaging.FlutterFirebaseMessagingReceiver"
            android:exported="true"
            android:permission="com.google.android.c2dm.permission.SEND">
            <intent-filter>
                <action android:name="com.google.android.c2dm.intent.RECEIVE" />
                <category android:name="${applicationId}" />
            </intent-filter>
        </receiver>

        <!-- ✅ Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Required by Flutter -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

    </application>

    <!-- Optional: If you use text processing plugins -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT" />
            <data android:mimeType="text/plain" />
        </intent>
    </queries>

</manifest>
